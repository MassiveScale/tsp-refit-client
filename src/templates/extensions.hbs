{{!--
  extensions.hbs — generates two top-level declarations in one file:
    1. A concrete `{clientClassName}` class that exposes each Refit interface
       as a named property (e.g. `client.Pets.ListAsync(ct)`).
    2. A static `{className}` extension class that registers all Refit interfaces
       and the aggregate client with ASP.NET Core's DI container.

  Override via tspconfig.yaml:
    options:
      "@massivescale/tsp-refit-client":
        templates:
          extensions: "./templates/extensions.hbs"

  ── Template variables ──────────────────────────────────────────────────────

  {{clientClassName}} — name of the aggregate client class, e.g. "ApiClient"

  {{className}}       — name of the static extensions class, e.g. "ApiClientExtensions"

  {{methodName}}      — name of the public registration method, e.g. "AddApiClient"

  {{interfaces}}      — array of interface entry objects. Each has:
    .name             —   C# interface name, e.g. "IPets"
    .propertyName     —   property name on the aggregate client, e.g. "Pets"
    .paramName        —   constructor parameter name, e.g. "pets"

  ── Usage example ────────────────────────────────────────────────────────────

  builder.Services.AddApiClient(c =>
  {
      c.BaseAddress = new Uri("https://api.example.com");
  });

  // Inject and call:
  public class MyService(ApiClient api)
  {
      public Task DoSomethingAsync(CancellationToken ct) =>
          api.Pets.ListAsync(ct);
  }

  ── Built-in helpers ────────────────────────────────────────────────────────

  {{indent <text>}}  — prefixes every non-empty line of <text> with 4 spaces

--}}
/// <summary>
/// Unified client providing access to all API endpoints.
/// </summary>
/// <remarks>
/// Inject this class directly and call methods through its named endpoint properties,
/// e.g. <c>client.Pets.ListAsync(ct)</c>.
/// </remarks>
public class {{clientClassName}}
{
{{#each interfaces}}    /// <summary>Gets the <see cref="{{name}}"/> client.</summary>
    public {{name}} {{propertyName}} { get; }
{{/each}}
    /// <summary>
    /// Initializes a new instance of <see cref="{{clientClassName}}"/>.
    /// </summary>
    public {{clientClassName}}({{#each interfaces}}{{name}} {{paramName}}{{#unless @last}}, {{/unless}}{{/each}})
    {
{{#each interfaces}}        {{propertyName}} = {{paramName}};
{{/each}}    }
}

/// <summary>
/// Extension methods to register the <see cref="{{clientClassName}}"/> with the DI container.
/// </summary>
public static class {{className}}
{
    /// <summary>
    /// Registers all Refit interfaces and the <see cref="{{clientClassName}}"/> aggregate client with the DI container.
    /// </summary>
    /// <param name="services">The service collection.</param>
    /// <param name="configureHttpClient">Configures the underlying <see cref="HttpClient"/> for every interface (e.g. set <c>BaseAddress</c>).</param>
    /// <param name="configureBuilder">
    /// Optional. Receives the <see cref="IHttpClientBuilder"/> for each interface and returns it, allowing
    /// additional configuration such as adding delegating handlers or Polly resilience policies.
    /// </param>
    public static IServiceCollection {{methodName}}(
        this IServiceCollection services,
        Action<HttpClient> configureHttpClient,
        Func<IHttpClientBuilder, IHttpClientBuilder>? configureBuilder = null)
    {
{{#each interfaces}}        AddSingleClient<{{name}}>(services, configureHttpClient, configureBuilder);
{{/each}}        services.AddTransient<{{clientClassName}}>();
        return services;
    }

    private static void AddSingleClient<T>(
        IServiceCollection services,
        Action<HttpClient> configureHttpClient,
        Func<IHttpClientBuilder, IHttpClientBuilder>? configureBuilder) where T : class
    {
        var builder = services
            .AddRefitClient<T>()
            .ConfigureHttpClient(configureHttpClient);
        configureBuilder?.Invoke(builder);
    }
}
